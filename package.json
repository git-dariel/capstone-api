{
	"name": "mental-health-api",
	"version": "1.0.0",
	"main": "index.js",
	"scripts": {
		"start": "nodemon index.ts",
		"lint": "eslint app/**/*.ts index.ts",
		"format": "eslint app/**/*.ts index.ts --fix",
		"test": "mocha --require ts-node/register tests/**/*.spec.ts --exit",
		"build": "NODE_ENV=production node --max-old-space-size=512 ./node_modules/webpack/bin/webpack.js --config webpack.config.js",
		"prod": "NODE_ENV=production node ./dist/server.ts",
		"postinstall": "if [ \"$NODE_ENV\" != \"production\" ]; then prisma generate; fi",
		"prisma-docs": "npx prisma studio",
		"prisma-migrate": "npx prisma migrate dev",
		"prisma-generate": "npx prisma generate",
		"prisma-format": "npx prisma format",
		"prisma-seed": "npx prisma db seed",
		"prisma-reset": "npx prisma migrate reset --force",
		"prepare": "husky",
		"generate-data": "ts-node scripts/generate-data.ts"
	},
	"prisma": {
		"seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
	},
	"author": "Mental Health",
	"license": "ISC",
	"description": "Mental Health API is a RESTful API built with TypeScript, Express, and Prisma. It provides a secure and efficient way to manage user authentication, authorization, and data storage.",
	"keywords": [
		"typescript",
		"express",
		"prisma",
		"api",
		"restful",
		"authentication"
	],
	"devDependencies": {
		"@logtail/node": "^0.5.2",
		"@logtail/winston": "^0.5.2",
		"@types/chai": "^5.2.1",
		"@types/cookie-parser": "^1.4.8",
		"@types/express": "^5.0.3",
		"@types/jsonwebtoken": "^9.0.9",
		"@types/mocha": "^10.0.10",
		"@types/mongodb": "^4.0.6",
		"@types/multer": "^2.0.0",
		"@types/node": "^22.18.9",
		"@types/swagger-jsdoc": "^6.0.4",
		"@types/swagger-ui-express": "^4.1.8",
		"@typescript-eslint/eslint-plugin": "^8.29.0",
		"@typescript-eslint/parser": "^8.29.0",
		"chai": "^4.5.0",
		"eslint": "^9.24.0",
		"eslint-config-prettier": "^10.1.1",
		"eslint-plugin-import": "^2.31.0",
		"eslint-plugin-prettier": "^5.2.6",
		"husky": "^9.1.7",
		"i": "^0.3.7",
		"mocha": "^11.1.0",
		"mongodb": "^6.17.0",
		"nodemon": "^3.1.9",
		"npm": "^11.2.0",
		"prisma": "^6.5.0",
		"swagger-jsdoc": "^6.2.8",
		"swagger-ui-express": "^5.0.1",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsx": "^4.19.3",
		"typescript": "^5.8.3",
		"webpack": "^5.96.1",
		"webpack-cli": "^5.1.4"
	},
	"dependencies": {
		"@faker-js/faker": "^8.4.1",
		"@prisma/client": "^6.5.0",
		"@types/bcrypt": "^5.0.2",
		"@types/node-cron": "^3.0.11",
		"@types/nodemailer": "^6.4.17",
		"argon2": "^0.41.1",
		"bcrypt": "^6.0.0",
		"canvas": "^3.1.2",
		"cloudinary": "^2.7.0",
		"cookie-parser": "^1.4.7",
		"csv-parse": "^5.6.0",
		"docx": "^9.5.1",
		"docxtemplater": "^3.67.2",
		"dotenv": "^16.6.1",
		"express": "^5.1.0",
		"http": "^0.0.1-security",
		"jsonwebtoken": "^9.0.2",
		"ml-cart": "^2.1.1",
		"ml-matrix": "^6.12.1",
		"ml-random-forest": "^2.1.0",
		"multer": "^2.0.2",
		"node-cron": "^4.2.1",
		"nodemailer": "^7.0.3",
		"pizzip": "^3.2.0",
		"random-forest": "^0.0.7",
		"socket.io": "^4.8.1",
		"winston": "^3.17.0"
	}
}