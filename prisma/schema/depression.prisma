enum DepressionFrequency {
  not_at_all
  several_days
  more_than_half_days
  nearly_every_day
}

enum DepressionSeverityLevel {
  minimal
  mild
  moderate
  moderately_severe
  severe
}

enum DepressionDifficultyLevel {
  not_difficult_at_all
  somewhat_difficult
  very_difficult
  extremely_difficult
}

model DepressionAssessment {
  id                                        String                    @id @default(auto()) @map("_id") @db.ObjectId
  user                                      User                      @relation(fields: [userId], references: [id])
  userId                                    String                    @db.ObjectId
  little_interest_pleasure_doing_things     DepressionFrequency       @default(not_at_all)
  feeling_down_depressed_hopeless           DepressionFrequency       @default(not_at_all)
  trouble_falling_staying_asleep_too_much   DepressionFrequency       @default(not_at_all)
  feeling_tired_having_little_energy        DepressionFrequency       @default(not_at_all)
  poor_appetite_overeating                  DepressionFrequency       @default(not_at_all)
  feeling_bad_about_yourself_failure        DepressionFrequency       @default(not_at_all)
  trouble_concentrating_things              DepressionFrequency       @default(not_at_all)
  moving_speaking_slowly_fidgety_restless   DepressionFrequency       @default(not_at_all)
  thoughts_better_off_dead_hurting_yourself DepressionFrequency       @default(not_at_all)
  totalScore                                Int                       @default(0) // Sum of all responses (0-27)
  severityLevel                             DepressionSeverityLevel   @default(minimal)
  assessmentDate                            DateTime                  @default(now())
  difficulty_level                          DepressionDifficultyLevel @default(not_difficult_at_all)
  createdAt                                 DateTime                  @default(now())
  updatedAt                                 DateTime                  @updatedAt
  isDeleted                                 Boolean                   @default(false)
}
