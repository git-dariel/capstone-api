type ChecklistAnalysis {
  totalProblemsChecked  Int
  totalCircledImportant Int
  categoryScores        Json // Object with category -> count mapping
  riskLevel             RiskLevel
  urgencyLevel          UrgencyLevel
  riskFactors           String[]
  recommendations       String[]
  needsAttention        Boolean
  analysisDate          DateTime     @default(now())
  disclaimer            String       @default("This checklist is for informational purposes only and does not replace professional psychological assessment. Please consult with a qualified mental health professional for proper evaluation and treatment.")
}

model PersonalProblemsChecklist {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique @db.ObjectId

  // Date completed (basic info like name, age, gender can be retrieved from student.person)
  date_completed DateTime @default(now())

  // Problem Categories
  social_friends_problems   SocialFriendsProblems
  appearance_problems       AppearanceProblems
  attitude_opinion_problems AttitudeOpinionProblems
  parents_problems          ParentsProblems
  family_home_problems      FamilyHomeProblems
  school_problems           SchoolProblems
  money_problems            MoneyProblems
  religion_problems         ReligionProblems
  emotional_problems        EmotionalProblems
  dating_sex_problems       DatingSexProblems

  // Analysis and Assessment
  checklist_analysis ChecklistAnalysis?
  analysisGenerated  Boolean            @default(false)
  analysisUpdatedAt  DateTime?

  // Additional fields following your pattern
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
