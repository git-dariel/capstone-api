enum ChecklistCategory {
  social_friends // SOC/FR
  appearance // APP
  attitude_opinion // ATT/OPIN
  parents // PAR
  family_home // FAM/HOM
  school // SCH
  money // MON
  religion // REL
  emotional // EMOT
  dating_sex // DAT/SEX
}

enum ProblemSeverity {
  not_checked
  checked
  circled_most_important
}

enum RiskLevel {
  low
  moderate
  high
  critical
}

enum UrgencyLevel {
  none
  monitor
  schedule
  immediate
}

