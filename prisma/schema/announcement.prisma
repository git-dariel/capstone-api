enum AnnouncementStatus {
  academic
  career
  wellness
}

model Announcement {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  status      AnnouncementStatus @default(academic)
  attachement String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime
  isDeleted   Boolean            @default(false)
}
