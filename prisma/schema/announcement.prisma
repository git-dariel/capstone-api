enum AnnouncementStatus {
  academic
  career
  wellness
}

type AnnouncementFiles {
  name String?
  url  String?
}

model Announcement {
  id          String              @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  status      AnnouncementStatus  @default(academic)
  attachement AnnouncementFiles[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime
  isDeleted   Boolean             @default(false)
}
